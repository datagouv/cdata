{
  // https://nuxt.com/docs/guide/concepts/typescript
  "extends": "./.nuxt/tsconfig.json",
  // Nuxt 4 enables strict and noUncheckedIndexedAccess by default.
  // Disabled for now to unblock the migration, to be re-enabled incrementally.
  "compilerOptions": {
    "strict": false,
    "noUncheckedIndexedAccess": false
  },
  // datagouv-components is treated as an external dependency, so only its production
  // dependencies are installed (not devDependencies). We exclude config files that require
  // these devDependencies. Typecheck for these files is done in CI via check-components-quality.
  "exclude": ["datagouv-components/*.config.ts"]
}
