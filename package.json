{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">= 24.0.0",
    "pnpm": ">= 10.0.0",
    "npm": "use-pnpm-instead",
    "yarn": "use-pnpm-instead"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@scarf/scarf",
      "@tailwindcss/oxide",
      "cypress",
      "esbuild",
      "husky",
      "sharp"
    ],
    "ignoredBuiltDependencies": [
      "@sentry/cli",
      "core-js",
      "unrs-resolver",
      "vue-demi"
    ],
    "patchedDependencies": {
      "@nuxt/nitro-server": "patches/@nuxt__nitro-server.patch"
    }
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint-staged": "lint-staged",
    "build": "NODE_OPTIONS=--max-old-space-size=8192 nuxt build",
    "typecheck": "nuxt typecheck",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "prepare": "husky",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:update-screenshots": "playwright test tests/homepage.spec.ts tests/edito/pages-editor.spec.ts --update-snapshots",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:show-report": "bash -c 'rm -rf /tmp/playwright && mkdir /tmp/playwright && mv \"$1\" /tmp/playwright/report.zip && unzip -d /tmp/playwright /tmp/playwright/report.zip && pnpm exec playwright show-report /tmp/playwright' _"
  },
  "lint-staged": {
    "*.{js,ts,vue,jsx,tsx}": "eslint --fix"
  },
  "dependencies": {
    "@datagouv/components-next": "workspace:*",
    "@floating-ui/vue": "^1.1.11",
    "@gouvfr/dsfr": "^1.14.4",
    "@headlessui/vue": "^1.7.23",
    "@milkdown/core": "^7.21.1",
    "@milkdown/ctx": "^7.21.1",
    "@milkdown/plugin-clipboard": "^7.21.1",
    "@milkdown/plugin-history": "^7.21.1",
    "@milkdown/plugin-listener": "^7.21.1",
    "@milkdown/plugin-tooltip": "^7.21.1",
    "@milkdown/preset-commonmark": "^7.21.1",
    "@milkdown/preset-gfm": "^7.21.1",
    "@milkdown/prose": "^7.21.1",
    "@milkdown/transformer": "^7.21.1",
    "@milkdown/vue": "^7.21.1",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/sitemap": "^8.0.15",
    "@prosemirror-adapter/vue": "^0.5.3",
    "@remixicon/vue": "^4.9.0",
    "@rollup/pluginutils": "^5.3.0",
    "@sentry/nuxt": "^10.54.0",
    "@tailwindcss/vite": "^4.3.0",
    "@takumi-rs/core": "^1.6.0",
    "@types/papaparse": "^5.5.2",
    "@types/tabulator-tables": "^6.3.3",
    "@vueuse/core": "^14.3.0",
    "@vueuse/integrations": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "@vueuse/router": "^14.3.0",
    "dompurify": "^3.4.7",
    "gray-matter": "^4.0.3",
    "leaflet": "^1.9.4",
    "lodash-es": "^4.18.1",
    "nuxt": "~4.4.6",
    "nuxt-og-image": "^6.5.1",
    "ofetch": "^1.5.1",
    "papaparse": "^5.5.3",
    "sharp": "^0.34.5",
    "smol-toml": "^1.6.1",
    "sortablejs": "^1.15.7",
    "tabulator-tables": "^6.4.0",
    "uqr": "^0.1.3",
    "uuid": "^14.0.0",
    "vue-content-loader": "^2.0.1",
    "vue-router": "^5.0.7",
    "vue3-text-clamp": "^0.1.2",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/fonts": "^0.14.0",
    "@parcel/watcher": "^2.5.6",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/oxide": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/geojson": "^7946.0.16",
    "@types/leaflet": "^1.9.21",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.12.4",
    "@types/sortablejs": "^1.15.9",
    "@vitejs/plugin-vue": "^6.0.6",
    "husky": "^9.1.7",
    "lightningcss": "^1.32.0",
    "lint-staged": "^16.4.0",
    "otplib": "^13.4.0",
    "sass-embedded": "^1.100.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8",
    "vue-component-type-helpers": "^3.3.2",
    "vue-tsc": "^3.3.2"
  }
}
